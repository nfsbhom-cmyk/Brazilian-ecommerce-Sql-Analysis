_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="orders_multiple_items" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="257"/><column index="2" value="77"/><column index="3" value="75"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="payments_clean" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="257"/><column index="2" value="121"/><column index="3" value="93"/><column index="4" value="132"/><column index="5" value="94"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="top_customers" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="257"/><column index="2" value="78"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 2">SELECT * FROM olist_orders_dataset LIMIT 10;
SELECT * FROM olist_order_items_dataset LIMIT 10;
SELECT * FROM olist_order_payments_dataset LIMIT 10;
-- Data quality checks:
-- Missing timestamps
SELECT * 
FROM olist_orders_dataset
WHERE order_purchase_timestamp IS NULL 
   OR order_purchase_timestamp = '';

-- Invalid payments
SELECT *
FROM olist_order_payments_dataset
WHERE payment_value IS NULL OR payment_value &lt;= 0;

-- Invalid prices
SELECT *
FROM olist_order_items_dataset
WHERE price &lt; 0;

-- Orders
CREATE TABLE orders_clean AS
SELECT DISTINCT *
FROM olist_orders_dataset
WHERE order_purchase_timestamp IS NOT NULL
  AND order_purchase_timestamp != '';

-- Order items
CREATE TABLE order_items_clean AS
SELECT *
FROM olist_order_items_dataset
WHERE price &gt;= 0;

-- Payments
CREATE TABLE payments_clean AS
SELECT *
FROM olist_order_payments_dataset
WHERE payment_value &gt; 0;

CREATE VIEW commerce_analysis AS
SELECT 
    o.order_id,
    o.customer_id,
    DATE(o.order_purchase_timestamp) AS order_date,
    oi.product_id,
    oi.price,
    p.payment_value,
FROM orders_clean o
JOIN order_items_clean oi ON o.order_id = oi.order_id
JOIN payments_clean p ON o.order_id = p.order_id;

CREATE TABLE monthly_revenue AS
SELECT strftime('%Y-%m', order_date) AS month,
       SUM(payment_value) AS revenue
FROM commerce_analysis
GROUP BY month;


CREATE TABLE IF NOT EXISTS top_customers AS
SELECT customer_id, SUM(payment_value) AS total_spent
FROM commerce_analysis
GROUP BY customer_id
ORDER BY total_spent DESC
LIMIT 10;


CREATE TABLE best_products AS
SELECT product_id, COUNT(order_item_id) AS total_sold,
       SUM(price) AS revenue
FROM order_items_clean
GROUP BY product_id
ORDER BY total_sold DESC
LIMIT 10;

CREATE TABLE orders_multiple_items AS
SELECT order_id, COUNT(order_item_id) AS items_count,
       SUM(price) AS order_value
FROM order_items_clean
GROUP BY order_id
HAVING items_count &gt; 1;


CREATE TABLE IF NOT EXISTS Total_revenue AS
SELECT SUM(payment_value) AS total_revenue
FROM payments_clean; 

CREATE TABLE IF NOT EXISTS Average_order_values AS
SELECT AVG(order_value) AS avg_order_value
FROM (
SELECT order_id, SUM(payment_value) AS order_value
FROM payments_clean
GROUP BY order_id
); 



</sql><current_tab id="0"/></tab_sql></sqlb_project>
